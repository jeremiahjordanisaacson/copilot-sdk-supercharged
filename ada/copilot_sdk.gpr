--  Copilot SDK for Ada -- GNAT Project File
--
--  Build with:
--    gprbuild -P copilot_sdk.gpr
--
--  Or use Alire:
--    alr build
--

project Copilot_SDK is

   for Source_Dirs use ("src");
   for Object_Dir use "obj";
   for Library_Dir use "lib";
   for Library_Name use "copilot_sdk";
   for Library_Kind use "static";

   package Compiler is
      for Default_Switches ("Ada") use
        ("-gnat2012",   --  Ada 2012 standard
         "-gnata",      --  enable assertions
         "-gnatwa",     --  all warnings
         "-gnatVa",     --  all validity checks
         "-gnatQ",      --  generate ALI even on errors
         "-gnatyM120",  --  max line length 120
         "-O2");        --  optimization level 2
   end Compiler;

   package Binder is
      for Default_Switches ("Ada") use ("-Es");  --  symbolic tracebacks
   end Binder;

   package Linker is
      for Default_Switches ("Ada") use ("-g");
   end Linker;

end Copilot_SDK;
