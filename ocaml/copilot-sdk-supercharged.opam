depends: [
  "ocaml" {>= "4.14"}
  "dune" {>= "3.0"}
  "lwt" {>= "5.6"}
  "lwt_ppx" {>= "2.1"}
  "yojson" {>= "2.0"}
  "alcotest" {with-test & >= "1.7"}
  "alcotest-lwt" {with-test & >= "1.7"}
]
build: [
  ["dune" "build" "-p" name "-j" jobs]
  ["dune" "runtest" "-p" name "-j" jobs] {with-test}
]
dev-repo: "git+https://github.com/jeremiahjordanisaacson/copilot-sdk-supercharged.git"
