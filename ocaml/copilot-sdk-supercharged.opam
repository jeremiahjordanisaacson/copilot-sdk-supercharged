opam-version: "2.0"
name: "copilot-sdk-supercharged"
version: "0.1.0"
synopsis: "OCaml SDK for GitHub Copilot CLI via JSON-RPC"
description: """
A client library for programmatic control of GitHub Copilot CLI
via JSON-RPC 2.0 over stdio or TCP, with Content-Length header
framing (LSP protocol style).
"""
maintainer: ["Jeremiah Isaacson"]
authors: ["Jeremiah Isaacson"]
license: "MIT"
homepage: "https://github.com/jeremiahjordanisaacson/copilot-sdk-supercharged"
