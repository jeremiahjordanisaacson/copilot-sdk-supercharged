      "rootUri": "scala"
    },
    "crystal": {
      "command": "crystalline",
      "args": [],
      "fileExtensions": {
        ".cr": "crystal"
      },
      "rootUri": "crystal"
    },
    "ada": {
      "command": "ada_language_server",
      "args": [],
      "fileExtensions": {
        ".ads": "ada",
        ".adb": "ada"
      },
      "rootUri": "ada"
    },
    "fortran": {
      "command": "fortls",
      "args": [],
      "fileExtensions": {
        ".f90": "fortran",
        ".f95": "fortran",
        ".f03": "fortran"
      },
      "rootUri": "fortran"
    }
